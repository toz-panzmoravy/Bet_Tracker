# BetTracker Backend – příklad konfigurace (zkopírujte do .env a upravte)

# Databáze (výchozí pro lokální vývoj)
# DATABASE_URL=postgresql://bettracker:bettracker123@localhost:5432/bettracker

# Port API (výchozí 15555)
# PORT=15555

# Fotbal – live skóre z football-data.org (volitelné)
# FOOTBALL_DATA_ORG_API_KEY=
